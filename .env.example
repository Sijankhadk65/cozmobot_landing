# Contact form delivery (Resend — https://resend.com)
# Without both of these set, the form renders and validates but returns an
# error telling the visitor to email info@cozmobot.com directly.

# API key from the Resend dashboard.
RESEND_API_KEY=

# The From: address. Must be on a domain verified in Resend.
# e.g. "nex-ON <hello@cozmobot.com>"
CONTACT_FROM_EMAIL=
